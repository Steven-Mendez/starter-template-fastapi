{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Etc/UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"],
    "prCreation": "immediate",
    "automerge": true,
    "automergeType": "pr"
  },
  "pre-commit": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true,
    "pinDigests": true
  },
  "packageRules": [
    {
      "groupName": "pytest",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["pytest", "pytest-asyncio", "pytest-clarity", "pytest-cov", "pytest-html", "pytest-randomly", "pytest-sugar"]
    },
    {
      "groupName": "fastapi-pydantic",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["fastapi", "starlette", "pydantic", "pydantic-settings"]
    },
    {
      "groupName": "sqlmodel-stack",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["sqlmodel", "sqlalchemy", "alembic"]
    },
    {
      "groupName": "arq-redis",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["arq", "redis", "fakeredis"]
    },
    {
      "groupName": "boto3",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["boto3", "botocore", "boto3-stubs", "moto"]
    },
    {
      "groupName": "dev-tooling",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["ruff", "mypy", "import-linter", "pre-commit", "pip-audit"]
    },
    {
      "groupName": "production-deps",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies", "optional-dependencies"],
      "schedule": ["before 5am on monday"]
    },
    {
      "groupName": "dev-deps",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups"],
      "schedule": ["before 5am on monday"]
    },
    {
      "groupName": "pre-commit-hooks",
      "matchManagers": ["pre-commit"],
      "schedule": ["before 5am on monday"]
    },
    {
      "description": "Major-version bumps (including security advisories whose fix is a major) require human review.",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Track digest bumps for the production Dockerfile's pinned base images.",
      "matchManagers": ["dockerfile"],
      "pinDigests": true,
      "updatePinnedDependencies": true
    }
  ]
}
