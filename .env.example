APP_ENABLE_DOCS=true
APP_ENVIRONMENT=development
APP_LOG_LEVEL=DEBUG
APP_CORS_ORIGINS=["*"]
APP_TRUSTED_HOSTS=["*"]
# Public-facing URL embedded in transactional email links (password
# reset, email verification). Production REFUSES to start unless:
#   1. APP_APP_PUBLIC_URL is set
#   2. it uses the https:// scheme
#   3. its host appears in APP_CORS_ORIGINS (single source of truth
#      for "trusted surface")
# Example (production): APP_APP_PUBLIC_URL=https://app.example.com
APP_APP_PUBLIC_URL=http://localhost:8000
# CIDR ranges of upstream proxies whose ``X-Forwarded-For`` headers are
# trusted. Required in production so the auth rate limiter sees real
# client IPs instead of the load balancer's address — production
# refuses to start when this list is empty. Leave empty in development
# (single-machine, no proxy).
#
# WARNING: do NOT set this to "0.0.0.0/0". That trusts every caller's
# ``X-Forwarded-For`` and lets attackers spoof their client IP to
# bypass per-IP rate limits. Always name the explicit CIDR(s) of your
# load balancer / ingress controller.
# Example: APP_TRUSTED_PROXY_IPS=["10.0.0.0/8", "192.168.0.0/16"]
APP_TRUSTED_PROXY_IPS=[]
APP_POSTGRESQL_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/kanban
APP_HEALTH_PERSISTENCE_BACKEND=postgresql

# Observability
APP_METRICS_ENABLED=true
# Example: APP_OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
APP_OTEL_EXPORTER_ENDPOINT=
APP_OTEL_SERVICE_NAME=starter-template-fastapi
APP_OTEL_SERVICE_VERSION=0.1.0
# Graceful-shutdown budget shared by the API and the worker (seconds).
# Set the K8s terminationGracePeriodSeconds to this value + 5 s slack.
APP_SHUTDOWN_TIMEOUT_SECONDS=30.0

# Auth/RBAC settings. Set a strong secret in local/prod env files; do not commit it.
# Production REFUSES to start when this is shorter than 32 characters and the
# JWT algorithm is HMAC-based (HS256/HS384/HS512). Generate one with:
#   openssl rand -hex 32
APP_AUTH_JWT_SECRET_KEY=change-me-in-production
APP_AUTH_JWT_ALGORITHM=HS256
APP_AUTH_JWT_ISSUER=
APP_AUTH_JWT_AUDIENCE=
APP_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
APP_AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAMESITE=lax
APP_AUTH_PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
APP_AUTH_EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=1440
APP_AUTH_RATE_LIMIT_ENABLED=true
# Per-account lockout limiter. AND-composed with the per-(ip, email)
# limiter so a botnet that rotates IPs still trips an absolute
# per-account budget. Tune the window higher than the burst limiter so
# the budget covers a full session of a determined attacker.
APP_AUTH_PER_ACCOUNT_LOGIN_MAX_ATTEMPTS=20
APP_AUTH_PER_ACCOUNT_LOGIN_WINDOW_SECONDS=3600
APP_AUTH_PER_ACCOUNT_RESET_MAX_ATTEMPTS=20
APP_AUTH_PER_ACCOUNT_RESET_WINDOW_SECONDS=3600
APP_AUTH_PER_ACCOUNT_VERIFY_MAX_ATTEMPTS=20
APP_AUTH_PER_ACCOUNT_VERIFY_WINDOW_SECONDS=3600
APP_AUTH_RBAC_ENABLED=true
# Local bootstrap only. Change or disable outside local development.
APP_AUTH_SEED_ON_STARTUP=true
APP_AUTH_BOOTSTRAP_SUPER_ADMIN_EMAIL=root@example.com
APP_AUTH_BOOTSTRAP_SUPER_ADMIN_PASSWORD=root
# Default-deny: when false (the default) the bootstrap use case refuses
# to promote an account that already exists with the configured email
# unless it already holds ``system:main#admin`` (the idempotent re-run
# case). Flip to true ONLY if you intentionally pre-created the account
# through another channel and you can supply that user's actual
# password — the password is verified against the stored credential
# before any ``system:main#admin`` relationship is written.
APP_AUTH_BOOTSTRAP_PROMOTE_EXISTING=false
APP_AUTH_DEFAULT_USER_ROLE=user
APP_AUTH_SUPER_ADMIN_ROLE=super_admin
APP_AUTH_RETURN_INTERNAL_TOKENS=false
# Set to enable distributed rate limiting and multi-replica principal cache.
# REQUIRED in production: without Redis BOTH the rate limiter AND the
# principal cache fall back to in-process state, so per-replica
# counters multiply the effective limit by worker count and revoked
# principals keep acting on workers that did not see the invalidation.
# Set APP_AUTH_REQUIRE_DISTRIBUTED_RATE_LIMIT=false to opt out
# explicitly for single-replica deployments.
# Example: APP_AUTH_REDIS_URL=redis://localhost:6379/0
# APP_AUTH_REDIS_URL=
APP_AUTH_PRINCIPAL_CACHE_TTL_SECONDS=5

# Email. `console` logs the rendered message and is the only backend
# (dev/test). Production email arrives with AWS SES at a later roadmap
# step; until then production refuses to start with `console`.
APP_EMAIL_BACKEND=console
APP_EMAIL_FROM=
# Console adapter only. When true (AND APP_ENVIRONMENT=development),
# the rendered body is logged in addition to body_len/body_sha256.
# Leave false to keep single-use reset/verify tokens out of logs.
APP_EMAIL_CONSOLE_LOG_BODIES=false

# File storage. Defaults are fine when no consumer feature uses storage.
# Set APP_STORAGE_ENABLED=true to opt in (production then requires 's3').
APP_STORAGE_ENABLED=false
APP_STORAGE_BACKEND=local
APP_STORAGE_LOCAL_PATH=./var/storage
APP_STORAGE_S3_BUCKET=
APP_STORAGE_S3_REGION=us-east-1

# Optional overrides used by docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kanban
APP_POSTGRESQL_DSN_DOCKER=postgresql+psycopg://postgres:postgres@db:5432/kanban
