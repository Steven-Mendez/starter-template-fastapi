APP_ENABLE_DOCS=true
APP_ENVIRONMENT=development
APP_LOG_LEVEL=DEBUG
APP_CORS_ORIGINS=["*"]
APP_TRUSTED_HOSTS=["*"]
APP_POSTGRESQL_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/kanban
APP_HEALTH_PERSISTENCE_BACKEND=postgresql

# Observability
APP_METRICS_ENABLED=true
# Example: APP_OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
APP_OTEL_EXPORTER_ENDPOINT=
APP_OTEL_SERVICE_NAME=starter-template-fastapi
APP_OTEL_SERVICE_VERSION=0.1.0

# Auth/RBAC settings. Set a strong secret in local/prod env files; do not commit it.
APP_AUTH_JWT_SECRET_KEY=change-me-in-production
APP_AUTH_JWT_ALGORITHM=HS256
APP_AUTH_JWT_ISSUER=
APP_AUTH_JWT_AUDIENCE=
APP_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
APP_AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAMESITE=lax
APP_AUTH_PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
APP_AUTH_EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=1440
APP_AUTH_RATE_LIMIT_ENABLED=true
APP_AUTH_RBAC_ENABLED=true
# Local bootstrap only. Change or disable outside local development.
APP_AUTH_SEED_ON_STARTUP=true
APP_AUTH_BOOTSTRAP_SUPER_ADMIN_EMAIL=root@example.com
APP_AUTH_BOOTSTRAP_SUPER_ADMIN_PASSWORD=root
APP_AUTH_DEFAULT_USER_ROLE=user
APP_AUTH_SUPER_ADMIN_ROLE=super_admin
APP_AUTH_RETURN_INTERNAL_TOKENS=false
APP_AUTH_OAUTH_ENABLED=false
APP_AUTH_OAUTH_GOOGLE_CLIENT_ID=
APP_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=
APP_AUTH_OAUTH_GOOGLE_REDIRECT_URI=
# Set to enable distributed rate limiting and multi-replica principal cache (requires Redis).
# Example: APP_AUTH_REDIS_URL=redis://localhost:6379/0
# APP_AUTH_REDIS_URL=
APP_AUTH_PRINCIPAL_CACHE_TTL_SECONDS=5

# Email. `console` logs the rendered message (dev/test default).
# `smtp` and `resend` are the production-shaped backends.
APP_EMAIL_BACKEND=console
APP_EMAIL_FROM=
# SMTP — fill these when APP_EMAIL_BACKEND=smtp
APP_EMAIL_SMTP_HOST=
APP_EMAIL_SMTP_PORT=587
APP_EMAIL_SMTP_USERNAME=
APP_EMAIL_SMTP_PASSWORD=
APP_EMAIL_SMTP_USE_STARTTLS=true
APP_EMAIL_SMTP_USE_SSL=false
APP_EMAIL_SMTP_TIMEOUT_SECONDS=10.0
# Resend — fill these when APP_EMAIL_BACKEND=resend
APP_EMAIL_RESEND_API_KEY=
APP_EMAIL_RESEND_BASE_URL=https://api.resend.com

# File storage. Defaults are fine when no consumer feature uses storage.
# Set APP_STORAGE_ENABLED=true to opt in (production then requires 's3').
APP_STORAGE_ENABLED=false
APP_STORAGE_BACKEND=local
APP_STORAGE_LOCAL_PATH=./var/storage
APP_STORAGE_S3_BUCKET=
APP_STORAGE_S3_REGION=us-east-1

# Optional overrides used by docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kanban
APP_POSTGRESQL_DSN_DOCKER=postgresql+psycopg://postgres:postgres@db:5432/kanban
